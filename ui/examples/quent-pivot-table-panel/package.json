{
  "name": "@quent-examples/quent-pivot-table-panel",
  "version": "0.1.0",
  "description": "Grafana panel plugin that renders Quent operator statistics in a pivot table.",
  "private": true,
  "scripts": {
    "build": "webpack -c ./webpack.config.cjs --mode production",
    "dev": "webpack -w -c ./webpack.config.cjs --mode development",
    "typecheck": "tsc --noEmit",
    "server": "docker compose up --build",
    "server:down": "docker compose down"
  },
  "dependencies": {
    "@quent/components": "link:../../packages/@quent/components",
    "@quent/hooks": "link:../../packages/@quent/hooks",
    "@quent/utils": "link:../../packages/@quent/utils",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "jotai": "^2.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@grafana/data": "^12.0.0",
    "@grafana/runtime": "^12.0.0",
    "@grafana/ui": "^12.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.35",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "resolve": "^1.22.12",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "webpack": "^5.99.0",
    "webpack-cli": "^6.0.1"
  },
  "peerDependencies": {
    "@grafana/data": "*",
    "@grafana/runtime": "*",
    "@grafana/ui": "*"
  }
}
